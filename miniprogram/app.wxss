page {
  background: #f6f3ea;
  color: #1f261d;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page {
  padding: 24rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border: 1rpx solid #ded8c8;
  border-radius: 16rpx;
  background: #fffdf7;
  box-shadow: 0 16rpx 36rpx rgba(54, 73, 42, 0.08);
}

.title {
  margin: 0 0 12rpx;
  color: #23482c;
  font-size: 40rpx;
  font-weight: 800;
}

.subtitle,
.muted {
  color: #66715f;
  font-size: 26rpx;
  line-height: 1.6;
}

.button {
  display: block;
  margin-top: 18rpx;
  border-radius: 12rpx;
  background: #23482c;
  color: #fff;
}

.ghost {
  background: #eef5e7;
  color: #23482c;
}

.tag {
  display: inline-block;
  margin: 0 12rpx 12rpx 0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #eef5e7;
  color: #23482c;
  font-size: 22rpx;
  font-weight: 700;
}

.warning {
  background: #fff0df;
  color: #d97418;
}

.danger {
  background: #fff0ed;
  color: #a94b3b;
}
