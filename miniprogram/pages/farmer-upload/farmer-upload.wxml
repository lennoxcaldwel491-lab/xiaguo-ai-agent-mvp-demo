<view class="page">
  <view class="card">
    <view class="title">上传苹果图片</view>
    <button class="button" data-source="camera" bindtap="chooseImage">拍摄苹果</button>
    <button class="button ghost" data-source="album" bindtap="chooseImage">从相册选择</button>
  </view>

  <view class="card">
    <view class="title small">已上传商品状态</view>
    <block wx:if="{{products.length}}">
      <view
        wx:for="{{products}}"
        wx:key="id"
        class="product-row"
        data-id="{{item.id}}"
        bindtap="goStatus"
      >
        <image class="thumb" src="{{item.image}}" mode="aspectFill"></image>
        <view class="product-copy">
          <view>
            <text class="tag {{item.statusClass}}">{{item.statusLabel}}</text>
            <text class="tag">{{item.grade}}</text>
          </view>
          <view class="row-title">{{item.title}}</view>
          <view class="subtitle">{{item.origin}} · {{item.weight}}kg · {{item.defect}}</view>
        </view>
      </view>
    </block>
    <view wx:else class="empty">暂无已上传商品</view>
  </view>
</view>
