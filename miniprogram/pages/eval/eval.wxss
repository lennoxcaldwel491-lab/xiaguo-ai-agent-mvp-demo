.metric-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin: 18rpx 0;
}

.metric-row view {
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f8fbf2;
}

.metric-row text,
.metric-row strong {
  display: block;
}

.metric-row text {
  color: #66715f;
  font-size: 22rpx;
}

.metric-row strong {
  margin-top: 6rpx;
  color: #23482c;
  font-size: 34rpx;
}

.case-row {
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eee7d7;
}

.case-row:last-child {
  border-bottom: 0;
}

.row-title {
  margin: 10rpx 0 4rpx;
  color: #1f261d;
  font-size: 28rpx;
  font-weight: 800;
}

.compact {
  display: inline-block;
  width: auto;
  min-width: 180rpx;
  margin: 14rpx 12rpx 0 0;
  padding: 0 18rpx;
  font-size: 24rpx;
}

.ok {
  background: #e8f4ed;
  color: #23482c;
}
