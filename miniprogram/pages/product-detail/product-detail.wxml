<view class="page">
  <view wx:if="{{product}}" class="card">
    <image class="hero" src="{{product.image}}" mode="aspectFill"></image>
    <view class="tag">{{product.grade}} 级瑕疵果</view>
    <view class="tag">{{product.origin}}</view>
    <view class="title">{{product.title}}</view>
    <view class="subtitle">¥{{product.price}} / {{product.weight}}kg</view>
  </view>
  <view wx:if="{{product}}" class="card">
    <view class="trust-item">
      <view class="tag">为什么便宜</view>
      <view class="muted">{{product.defect}}</view>
    </view>
    <view class="trust-item">
      <view class="tag">是否影响食用</view>
      <view class="muted">{{product.explanation}}</view>
    </view>
    <view class="trust-item">
      <view class="tag">平台兜底</view>
      <view class="muted">说明不符或有顾虑时可反馈，进入运营复盘。</view>
    </view>
    <button class="button" bindtap="submitIntent">提交购买意向</button>
    <button class="button ghost" bindtap="goFeedback">提交顾虑反馈</button>
  </view>
  <view wx:else class="card">
    <view class="title">商品不存在</view>
    <button class="button" bindtap="goList">返回商品列表</button>
  </view>
</view>
