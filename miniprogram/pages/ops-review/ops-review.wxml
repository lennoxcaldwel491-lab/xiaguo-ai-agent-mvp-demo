<view class="page">
  <view class="card">
    <view class="title">复核队列</view>
    <view class="subtitle">处理待复核商品，并回看消费者反馈。</view>
  </view>

  <block wx:if="{{reviews.length}}">
    <view wx:for="{{reviews}}" wx:key="id" class="card">
      <image class="thumb" src="{{item.image}}" mode="aspectFill"></image>
      <view class="title small">{{item.title}}</view>
      <view class="tag warning">复核</view>
      <view class="tag">{{item.grade}}</view>
      <view class="subtitle">{{item.defect}} · 置信度 {{item.confidence}}%</view>
      <button class="button" data-id="{{item.id}}" bindtap="approve">通过上架</button>
      <button class="button ghost" data-id="{{item.id}}" bindtap="requestMore">要求补图</button>
      <button class="button ghost" data-id="{{item.id}}" bindtap="reject">禁售并记坏例</button>
    </view>
  </block>
  <view wx:else class="card">
    <view class="title small">暂无待复核商品</view>
  </view>

  <view class="card">
    <view class="title small">消费者反馈复盘</view>
    <block wx:if="{{feedbacks.length}}">
      <view wx:for="{{feedbacks}}" wx:key="id" class="feedback-row">
        <view class="tag {{item.isIntent ? 'ok' : 'warning'}}">{{item.typeLabel}}</view>
        <view class="subtitle">{{item.content}}</view>
        <view class="muted">{{item.createdAt}}</view>
      </view>
    </block>
    <view wx:else class="empty">暂无购买意向或顾虑反馈</view>
  </view>
</view>
