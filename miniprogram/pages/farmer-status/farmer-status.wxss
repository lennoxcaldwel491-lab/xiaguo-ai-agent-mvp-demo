.hero {
  width: 100%;
  height: 430rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  background: #eef5e7;
}

.status-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin: 20rpx 0;
}

.status-grid view {
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f8fbf2;
}

.status-grid text,
.status-grid strong {
  display: block;
}

.status-grid text {
  color: #66715f;
  font-size: 22rpx;
}

.status-grid strong {
  margin-top: 6rpx;
  color: #1f261d;
  font-size: 26rpx;
}

.ok {
  background: #e8f4ed;
  color: #23482c;
}
