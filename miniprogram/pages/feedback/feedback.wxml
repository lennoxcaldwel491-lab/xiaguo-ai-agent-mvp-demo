<view class="page">
  <view class="card">
    <view class="title">提交购买意向</view>
    <view class="tag">1 箱试吃</view>
    <view class="tag">3-5 箱家庭团购</view>
    <view class="tag">10 箱以上批量意向</view>
    <button class="button" bindtap="submitIntent">提交购买意向</button>
  </view>
  <view class="card">
    <view class="title">有其他顾虑？</view>
    <view class="tag warning">我担心食用安全</view>
    <view class="tag warning">说明不够清楚</view>
    <view class="tag warning">价格不够有吸引力</view>
    <button class="button ghost" bindtap="submitFeedback">提交顾虑反馈</button>
  </view>
</view>
